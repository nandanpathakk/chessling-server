PORT=3001

# Supabase — find these at: supabase.com/dashboard → project → Settings → API
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY

# Solana RPC endpoint (use devnet for development)
SOLANA_RPC_URL=https://api.devnet.solana.com

# Treasury keypair — base64-encoded 64-byte secret key
# Generate with: node -e "const { Keypair } = require('@solana/web3.js'); const k = Keypair.generate(); console.log(Buffer.from(k.secretKey).toString('base64')); console.log(k.publicKey.toBase58())"
# Fund it on devnet: solana airdrop 2 <PUBLIC_KEY> --url devnet
TREASURY_SECRET_KEY=YOUR_BASE64_ENCODED_SECRET_KEY
TREASURY_PUBLIC_KEY=YOUR_TREASURY_PUBLIC_KEY
